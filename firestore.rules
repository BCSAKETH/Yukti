rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and write their own simulation data
    // For development/hackathon purposes, we use a permissive set
    // but limit to authenticated users if you enable Firebase Auth.
    // Currently set to allow all access to the 'simulations' and 'users' collections
    // for easier peer testing and friend debugging.
    
    match /simulations/{document=**} {
      allow read, write: if true;
    }
    
    match /users/{document=**} {
      allow read, write: if true;
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
